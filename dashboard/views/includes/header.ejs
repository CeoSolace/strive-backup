<header class="main-header">
  <style>
    /* ===== SAFE DARK MODE OVERRIDES (NO LAYOUT CHANGES) ===== */

    /* Logo area */
    .main-header .logo {
      background-color: #0f141b !important;
      color: #e6edf3 !important;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .main-header .logo:hover {
      background-color: #121a25 !important;
    }

    /* Navbar */
    .main-header .navbar {
      background-color: #0b0f14 !important;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    /* Navbar links + toggle */
    .main-header .navbar .nav > li > a,
    .main-header .navbar .sidebar-toggle {
      color: #e6edf3 !important;
    }

    .main-header .navbar .nav > li > a:hover,
    .main-header .navbar .sidebar-toggle:hover {
      background: rgba(255,255,255,0.06) !important;
      color: #ffffff !important;
    }

    /* Prevent white flash on click / focus */
    .main-header .navbar .nav > li > a:focus,
    .main-header .navbar .nav > li > a:active,
    .main-header .navbar .nav > li > a:visited {
      background: rgba(255,255,255,0.06) !important;
      color: #ffffff !important;
      outline: none;
    }

    /* Icon spacing */
    .main-header .navbar .nav > li > a i {
      margin-right: 6px;
    }

    /* Dropdown menu */
    .main-header .dropdown-menu {
      background: #0f141b !important;
      border: 1px solid rgba(255,255,255,0.1);
      padding: 8px;
    }

    .main-header .dropdown-menu a {
      color: #e6edf3 !important;
    }

    .main-header .dropdown-menu a:hover {
      background: rgba(255,255,255,0.06) !important;
    }

    /* ===== LOGOUT BUTTON VISIBILITY FIX ===== */
    .main-header .dropdown-menu .btn {
      background-color: #1a2332 !important;
      color: #ffffff !important;
      border: 1px solid rgba(255,255,255,0.25);
      font-weight: 600;
      text-align: center;
    }

    .main-header .dropdown-menu .btn:hover,
    .main-header .dropdown-menu .btn:focus,
    .main-header .dropdown-menu .btn:active {
      background-color: #243047 !important;
      color: #ffffff !important;
      border-color: rgba(255,255,255,0.4);
    }

    /* User image */
    .main-header .user-image {
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
    }
  </style>

  <!-- Logo -->
  <a href="/" class="logo">
    <span class="logo-mini"><b>SD</b></span>
    <span class="logo-lg"><b>Strive Dash</b></span>
  </a>

  <!-- Header Navbar -->
  <nav class="navbar navbar-static-top" role="navigation">
    <!-- Sidebar toggle -->
    <a class="sidebar-toggle" data-toggle="push-menu" role="button">
      <span class="sr-only">Toggle navigation</span>
    </a>

    <div class="navbar-custom-menu">
      <ul class="nav navbar-nav">

        <!-- Support Server Link -->
        <li>
          <a
            href="https://discord.gg/kgDrVng25h"
            target="_blank"
            rel="noopener noreferrer"
            title="Join our Support Server"
          >
            <i class="fa fa-life-ring"></i>
            <span class="hidden-xs">Support</span>
          </a>
        </li>

        <!-- User Menu -->
        <li class="dropdown user user-menu">
          <a href="#" class="dropdown-toggle" data-toggle="dropdown">
            <img
              src="<%= (user && user.displayAvatar) ? user.displayAvatar : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
              class="user-image"
              alt="User Image"
            />
            <span class="hidden-xs">
              <%= (user && user.tag) ? user.tag : "Discord User" %>
            </span>
          </a>

          <ul class="dropdown-menu">
            <li class="user-footer">
              <a href="/logout" class="btn btn-block">
                Sign out
              </a>
            </li>
          </ul>
        </li>

      </ul>
    </div>
  </nav>
</header>
