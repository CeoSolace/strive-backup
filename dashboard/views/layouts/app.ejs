<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />

    <%
      const titleEmojiMap = {
        'Overview': '🏠',
        'Servers': '🗂️',
        'Modules': '🧩',
        'Commands': '⌨️',
        'Automations': '⚡',
        'Logs': '📜',
        'Analytics': '📊',
        'Account': '👤',
        'Settings': '⚙️',
        'Billing': '💳',
        'News': '📰'
      };

      const _pt = (typeof pageTitle === 'string' && pageTitle.trim())
        ? pageTitle.trim()
        : 'Dashboard';

      const _emoji = titleEmojiMap[_pt] || '✨';
    %>

    <title><%= _emoji %> <%= _pt %> · Bright Dashboard</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: ['class'],
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'ui-sans-serif', 'system-ui'],
            },
            boxShadow: {
              soft: '0 1px 2px rgba(0,0,0,.06), 0 8px 24px rgba(0,0,0,.08)',
              panel: '0 10px 30px rgba(0,0,0,.10)',
            },
            colors: {
              brand: {
                50: '#f5f7ff',
                100: '#e9edff',
                200: '#cfd8ff',
                300: '#a8b8ff',
                400: '#7f8dff',
                500: '#5a63ff',
                600: '#4048e6',
                700: '#3338b4',
                800: '#2d318f',
                900: '#26296e',
              },
            },
          },
        },
      };
    </script>

    <!-- App Styles -->
    <link rel="stylesheet" href="/css/app.css" />

    <!-- Prevent theme flash -->
    <script>
      (function () {
        try {
          const saved = localStorage.getItem('bright_theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = saved || (prefersDark ? 'dark' : 'light');

          if (theme === 'dark') {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="h-full bg-zinc-100 text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-50">
    <div class="min-h-full">
      <div class="flex min-h-screen">

        <!-- Sidebar -->
        <%- include('../partials/sidebar', {
          user,
          activePath: (typeof activePath !== 'undefined' ? activePath : '')
        }) %>

        <!-- Main Content -->
        <div class="flex min-w-0 flex-1 flex-col">
          
          <!-- Topbar -->
          <div class="sticky top-0 z-30 border-b border-zinc-200/80 bg-white/80 backdrop-blur-xl dark:border-zinc-800 dark:bg-zinc-950/80">
            <%- include('../partials/topbar', { user }) %>
          </div>

          <!-- Page Content -->
          <main class="flex-1">
            <div class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
              <div class="rounded-3xl border border-zinc-200 bg-white p-4 shadow-soft dark:border-zinc-800 dark:bg-zinc-900/80 sm:p-6">
                <%- body %>
              </div>
            </div>
          </main>

          <!-- Toast Notifications -->
          <div
            id="toast-root"
            class="pointer-events-none fixed inset-x-0 bottom-4 z-50 flex flex-col items-center gap-2 px-4"
          ></div>
        </div>
      </div>
    </div>

    <!-- Global Scripts -->
    <script src="/js/app.js"></script>

    <!-- Toast System -->
    <script>
      window.showToast = function (message, type = 'info') {
        const root = document.getElementById('toast-root');

        const colors = {
          info: 'bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900',
          success: 'bg-green-600 text-white',
          error: 'bg-red-600 text-white',
        };

        const el = document.createElement('div');
        el.className = `pointer-events-auto px-4 py-2 rounded-xl shadow-panel text-sm font-medium ${colors[type]}`;
        el.textContent = message;

        root.appendChild(el);

        setTimeout(() => {
          el.style.opacity = '0';
          el.style.transform = 'translateY(8px)';
          el.style.transition = 'all .25s ease';
          setTimeout(() => el.remove(), 250);
        }, 2800);
      };
    </script>
  </body>
</html>
