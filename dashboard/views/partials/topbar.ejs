<header class="sticky top-0 z-40 border-b border-zinc-200/80 bg-white/85 backdrop-blur-xl supports-[backdrop-filter]:bg-white/75 dark:border-zinc-800 dark:bg-zinc-950/80">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-3 px-4 sm:px-6 lg:px-8">
    <!-- Left -->
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-3">
        <div class="hidden h-10 w-10 items-center justify-center rounded-2xl bg-brand-600 text-white shadow-soft sm:flex">
          <span class="text-sm font-bold">B</span>
        </div>

        <div class="min-w-0">
          <div class="truncate text-base font-semibold text-zinc-900 dark:text-zinc-50 sm:text-lg">
            Bright Dashboard
          </div>
          <div class="hidden truncate text-xs text-zinc-500 dark:text-zinc-400 sm:block">
            Manage your bot, servers, modules, commands, and automation from one place
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/app/servers"
        class="hidden items-center rounded-2xl border border-zinc-200 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:bg-zinc-50 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-200 dark:hover:bg-zinc-900 dark:hover:text-zinc-50 sm:inline-flex"
      >
        Manage Servers
      </a>

      <button
        type="button"
        class="inline-flex items-center gap-2 rounded-2xl bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-soft transition hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-white dark:focus:ring-offset-zinc-950"
        data-action="invite"
      >
        <span>Invite Bot</span>
      </button>

      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-zinc-200 bg-white text-zinc-600 shadow-sm transition hover:bg-zinc-50 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-900 dark:hover:text-zinc-50"
        data-action="toggle-theme"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <span class="text-lg">◐</span>
      </button>

      <!-- User Menu -->
      <div class="relative">
        <button
          type="button"
          class="flex items-center gap-3 rounded-2xl border border-zinc-200 bg-white px-3 py-2 text-left text-sm shadow-sm transition hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:bg-zinc-900"
          data-action="user-menu"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <img
            class="h-8 w-8 rounded-full ring-1 ring-zinc-200 dark:ring-zinc-800"
            src="<%= user?.displayAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
            alt=""
            referrerpolicy="no-referrer"
          />

          <div class="hidden min-w-0 sm:block">
            <div class="max-w-[12rem] truncate font-semibold text-zinc-900 dark:text-zinc-50">
              <%= user?.username || 'User' %>
            </div>
            <div class="max-w-[12rem] truncate text-xs text-zinc-500 dark:text-zinc-400">
              <%= user?.id || 'No ID' %>
            </div>
          </div>

          <div class="text-zinc-400">▾</div>
        </button>

        <div
          class="absolute right-0 mt-2 hidden w-60 overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-soft dark:border-zinc-800 dark:bg-zinc-950"
          role="menu"
          data-user-menu
        >
          <div class="border-b border-zinc-200 px-4 py-3 dark:border-zinc-800">
            <div class="truncate text-sm font-semibold text-zinc-900 dark:text-zinc-50">
              <%= user?.username || 'User' %>
            </div>
            <div class="truncate text-xs text-zinc-500 dark:text-zinc-400">
              <%= user?.id || '' %>
            </div>
          </div>

          <a
            class="block px-4 py-3 text-sm text-zinc-700 transition hover:bg-zinc-50 hover:text-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-900 dark:hover:text-zinc-50"
            href="/app/account/profile"
            role="menuitem"
          >
            Account
          </a>

          <a
            class="block px-4 py-3 text-sm text-zinc-700 transition hover:bg-zinc-50 hover:text-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-900 dark:hover:text-zinc-50"
            href="/app/settings"
            role="menuitem"
          >
            Settings
          </a>

          <div class="h-px bg-zinc-200 dark:bg-zinc-800"></div>

          <a
            class="block px-4 py-3 text-sm font-medium text-red-600 transition hover:bg-zinc-50 dark:hover:bg-zinc-900"
            href="/logout"
            role="menuitem"
          >
            Logout
          </a>
        </div>
      </div>
    </div>
  </div>
</header>
