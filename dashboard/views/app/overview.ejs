<% layout('layouts/app') -%>

<div class="container mx-auto px-6 py-8 space-y-8">

  <!-- WARNING -->
  <div class="rounded-xl border border-amber-300 bg-amber-50 p-4 text-amber-900">
    <strong>⚠️ WARNING:</strong>
    This dashboard is not fully production finished. Expect bugs, missing features, and incomplete functionality.
  </div>

  <!-- HEADER -->
  <div>
    <h1 class="text-3xl font-bold">Dashboard Overview</h1>
    <p class="text-gray-600 mt-1">
      Welcome back,
      <span class="font-semibold">
        <%= user?.username || user?.global_name || "User" %>
      </span>
    </p>
  </div>

  <!-- MAIN CARDS -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- DISCORD ACCOUNT -->
    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <h2 class="text-xl font-semibold mb-3">Discord Account</h2>

      <% if (user) { %>
        <div class="space-y-1 text-gray-800">
          <div><span class="font-medium">Username:</span> <%= user.username %></div>
          <div><span class="font-medium">ID:</span> <%= user.id %></div>
        </div>
      <% } else { %>
        <p class="text-gray-600">No user session detected.</p>
      <% } %>
    </div>

    <!-- BOT STATUS -->
    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <h2 class="text-xl font-semibold mb-3">Bot Status</h2>

      <div class="flex items-center gap-2">
        <span class="inline-block h-2 w-2 rounded-full <%= botClient ? 'bg-green-500' : 'bg-red-500' %>"></span>
        <span class="font-medium">
          <%= botClient ? "Online" : "Offline" %>
        </span>
      </div>

      <% if (botClient) { %>
        <div class="mt-3 space-y-1 text-gray-800">
          <div>
            <span class="font-medium">Guilds:</span>
            <%= botClient.guilds?.cache?.size || 0 %>
          </div>
          <div>
            <span class="font-medium">Uptime:</span>
            <%= botClient.uptime ? Math.floor(botClient.uptime / 60000) + " minutes" : "N/A" %>
          </div>
        </div>
      <% } else { %>
        <p class="mt-3 text-gray-600">Bot client not available.</p>
      <% } %>
    </div>

  </div>

  <!-- QUICK LINKS -->
  <div class="rounded-2xl border bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold mb-4">Quick Links</h2>

    <div class="flex flex-wrap gap-3">
      <a class="px-4 py-2 rounded-xl border hover:bg-gray-50 transition"
         href="<%= inviteUrl || '#' %>"
         target="_blank">
        Invite Bot
      </a>

      <a class="px-4 py-2 rounded-xl border hover:bg-gray-50 transition"
         href="<%= supportUrl || '#' %>"
         target="_blank">
        Support Server
      </a>
    </div>
  </div>

  <!-- SERVERS -->
  <div class="rounded-2xl border bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold mb-4">Your Servers</h2>

    <% const guilds = user?.guilds || []; %>

    <% if (guilds.length > 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <% guilds.forEach((g) => { %>
          <div class="rounded-xl border p-4 hover:shadow transition">

            <div class="font-semibold text-gray-900">
              <%= g.name %>
            </div>

            <div class="text-sm text-gray-600">
              ID: <%= g.id %>
            </div>

            <div class="mt-3">
              <a class="inline-flex px-3 py-2 rounded-lg border hover:bg-gray-50 transition"
                 href="/app/server/<%= g.id %>">
                Manage
              </a>
            </div>

          </div>
        <% }) %>

      </div>
    <% } else { %>
      <p class="text-gray-600">You are not currently managing any servers.</p>
    <% } %>
  </div>

</div>
