<% layout('layouts/app') -%>

<div class="container mx-auto px-6 py-8 space-y-6">
  <div>
    <h1 class="text-3xl font-bold">Analytics</h1>
    <p class="text-gray-600 mt-1">A quick snapshot of your dashboard activity.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <div class="text-sm text-gray-600">Admin guilds</div>
      <div class="text-3xl font-bold mt-1"><%= analytics?.guildCount ?? 0 %></div>
    </div>

    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <div class="text-sm text-gray-600">Automations (total)</div>
      <div class="text-3xl font-bold mt-1"><%= analytics?.automationsCount ?? 0 %></div>
    </div>

    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <div class="text-sm text-gray-600">Settings changes</div>
      <div class="text-3xl font-bold mt-1"><%= analytics?.settingsChanges ?? 0 %></div>
    </div>

    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <div class="text-sm text-gray-600">Modules toggled</div>
      <div class="text-3xl font-bold mt-1"><%= analytics?.modulesChanged ?? 0 %></div>
    </div>

    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <div class="text-sm text-gray-600">Commands toggled</div>
      <div class="text-3xl font-bold mt-1"><%= analytics?.commandsChanged ?? 0 %></div>
    </div>
  </div>
</div>
