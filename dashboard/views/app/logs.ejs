<% layout('layouts/app') -%>

<div class="container mx-auto px-6 py-8 space-y-6">
  <div>
    <h1 class="text-3xl font-bold">Logs</h1>
    <p class="text-gray-600 mt-1">Recent actions you performed on the dashboard.</p>
  </div>

  <% if (logs && logs.items && logs.items.length > 0) { %>
    <div class="overflow-x-auto rounded-2xl border bg-white shadow-sm">
      <table class="min-w-full text-left text-sm">
        <thead class="border-b bg-gray-50">
          <tr>
            <th class="px-4 py-3 font-semibold text-gray-700">Time</th>
            <th class="px-4 py-3 font-semibold text-gray-700">Action</th>
            <th class="px-4 py-3 font-semibold text-gray-700">Guild</th>
          </tr>
        </thead>
        <tbody>
          <% logs.items.forEach(function(log) { %>
            <tr class="border-b last:border-0">
              <td class="px-4 py-3 text-gray-800"><%= new Date(log.createdAt).toLocaleString() %></td>
              <td class="px-4 py-3 text-gray-800"><%= log.action %></td>
              <td class="px-4 py-3 text-gray-800"><%= log.guildId || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div class="flex items-center gap-3">
      <% if (logs.hasPrev) { %>
        <a class="px-3 py-2 rounded-lg border hover:bg-gray-50" href="/app/logs?page=<%= (logs.page || 1) - 1 %>">Prev</a>
      <% } %>

      <span class="text-gray-600">Page <%= logs.page || 1 %></span>

      <% if (logs.hasNext) { %>
        <a class="px-3 py-2 rounded-lg border hover:bg-gray-50" href="/app/logs?page=<%= (logs.page || 1) + 1 %>">Next</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="rounded-2xl border bg-white p-6 shadow-sm">
      <p class="text-gray-600">No audit logs yet.</p>
    </div>
  <% } %>
</div>
