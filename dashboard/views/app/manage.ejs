<% layout('layouts/app') -%>

<script>window.guildId = "<%= guild?.id %>";</script>

<div class="bright-builder-shell">

  <aside class="builder-sidebar">
    <h2>Blocks</h2>
    <input class="block-search" placeholder="Search..." />
    <div id="blockLibrary"></div>
  </aside>

  <div class="builder-workspace">

    <div class="builder-topbar">
      <input id="featureName" placeholder="Feature name" />
      <button id="saveFeatureBtn" class="builder-btn">Save</button>
    </div>

    <div id="builderCanvas" class="builder-canvas"></div>

    <div id="tutorialBox" class="tutorial-box">
      <h3>Tutorial</h3>
      <p></p>
    </div>

  </div>

</div>

<link rel="stylesheet" href="/css/feature-builder.css">
<script src="/js/feature-builder.js"></script>
