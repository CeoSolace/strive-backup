<% layout('layouts/app') -%>

<% const safeGuild = guild || null; const safeTab = tab || 'overview'; %>

<div class="flex flex-col gap-6">
  <h1 class="text-2xl font-semibold">Feature Builder</h1>

  <% if (safeTab === 'automations') { %>

  <div class="grid gap-6 xl:grid-cols-4">

    <div class="card">
      <h2 class="font-semibold">Blocks</h2>
      <div id="blockLibrary"></div>
    </div>

    <div class="card xl:col-span-2">
      <h2 class="font-semibold">Build</h2>
      <input id="automationName" placeholder="Feature name" class="input" />
      <div id="canvas"></div>
      <button id="save" class="btn">Save</button>
    </div>

    <div class="card">
      <h2 class="font-semibold">Saved</h2>
      <div id="list"></div>
    </div>

  </div>

  <% } %>
</div>

<script>
const guildId = "<%= safeGuild?.id %>";

const blocksDef = {
  1: "Send Message",
  2: "Wait",
  3: "Add Role"
};

const blocks = [];

function renderLibrary(){
  const el = document.getElementById("blockLibrary");
  Object.entries(blocksDef).forEach(([id,name])=>{
    const b=document.createElement("button");
    b.innerText=name;
    b.onclick=()=>{blocks.push({id:Number(id),params:{}});renderCanvas();};
    el.appendChild(b);
  });
}

function renderCanvas(){
  const el=document.getElementById("canvas");
  el.innerHTML="";
  blocks.forEach((b,i)=>{
    const d=document.createElement("div");
    d.innerText=i+1+". "+blocksDef[b.id];
    el.appendChild(d);
  });
}

document.getElementById("save").onclick=async()=>{
  const name=document.getElementById("automationName").value;
  await fetch(`/api/guild/${guildId}/automations`,{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({name,f:blocks.map(b=>b.id),p:blocks.map(b=>b.params)})
  });
  alert("Saved");
};

renderLibrary();
</script>
