<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= user ? "Redirecting..." : "Bright Dashboard" %></title>

  <% if (user) { %>
    <meta http-equiv="refresh" content="0; url=/selector" />
  <% } %>

  <style>
    :root{
      /* Non-AI palette: graphite + muted emerald (ops/security vibe) */
      --accent: #2bd576;
      --accent-soft: rgba(43, 213, 118, 0.18);

      --bg: #0a0b0e;
      --bg-2: #0f1117;
      --card: #131621;
      --card-2: #161a2b;

      --text: #e8ebf4;
      --muted: #9aa3bf;
      --muted2: #7f88a3;
      --border: rgba(255,255,255,0.06);

      --shadow: 0 18px 50px rgba(0,0,0,.55);
      --shadow2: 0 10px 28px rgba(0,0,0,.35);

      --radius: 18px;
      --radius2: 14px;

      --max: 1100px;

      --danger: #e24c4c;
      --warn: #f0b429;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }

    body{
      margin:0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      color: var(--text);
      overflow-x:hidden;
      display:flex;
      flex-direction:column;
      min-height:100vh;

      /* Clean, non-AI background: graphite, subtle steel bloom, emerald hint */
      background:
        radial-gradient(1100px 650px at 80% -10%, rgba(255,255,255,0.06), transparent 60%),
        radial-gradient(900px 560px at 10% 0%, rgba(255,255,255,0.035), transparent 62%),
        radial-gradient(900px 560px at 50% 115%, rgba(43,213,118,0.10), transparent 55%),
        linear-gradient(180deg, var(--bg), var(--bg-2));
    }

    /* Subtle grid overlay (very light) */
    body:before{
      content:"";
      position:fixed;
      inset:0;
      background:
        linear-gradient(to right, rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 46px 46px;
      mask-image: radial-gradient(700px 450px at 50% 18%, rgba(0,0,0,.9), transparent 70%);
      pointer-events:none;
      opacity:.6;
    }

    .wrap{
      width:100%;
      max-width: var(--max);
      margin: 0 auto;
      padding: 28px 18px 40px;
      position:relative;
      z-index:1;
    }

    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      padding: 10px 4px 18px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      text-decoration:none;
      color: var(--text);
    }

    .logo{
      width:40px;
      height:40px;
      border-radius: 12px;
      background:
        radial-gradient(circle at 30% 30%, rgba(255,255,255,.18), transparent 55%),
        linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,.03));
      border: 1px solid var(--border);
      box-shadow: 0 0 0 1px rgba(255,255,255,.03), 0 16px 34px rgba(0,0,0,.35);
      position:relative;
      overflow:hidden;
    }
    .logo:after{
      content:"";
      position:absolute;
      inset:-20px;
      background: radial-gradient(240px 180px at 50% 30%, var(--accent-soft), transparent 60%);
      transform: rotate(12deg);
      opacity:.9;
      pointer-events:none;
    }

    .brand strong{
      font-size: 14px;
      letter-spacing: .35px;
      display:block;
    }
    .brand span{
      display:block;
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding: 10px 12px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(19,22,33,.55);
      color: var(--muted);
      font-size: 12px;
      text-decoration:none;
      backdrop-filter: blur(10px);
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }
    .pill:hover{
      transform: translateY(-1px);
      border-color: rgba(255,255,255,.10);
      background: rgba(19,22,33,.72);
    }

    .dot{
      width:8px;
      height:8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(43,213,118,.10);
    }

    .hero{
      display:grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 18px;
      align-items: stretch;
      margin-top: 10px;
    }

    .card{
      background: linear-gradient(180deg, rgba(19,22,33,.92), rgba(19,22,33,.72));
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow:hidden;
      position:relative;
    }

    /* subtle top sheen */
    .card:before{
      content:"";
      position:absolute;
      inset:-2px;
      background: radial-gradient(700px 240px at 20% 0%, rgba(255,255,255,.06), transparent 60%);
      pointer-events:none;
    }

    .card-inner{
      position:relative;
      padding: 26px;
    }

    h1{
      margin: 0 0 10px;
      font-size: clamp(34px, 4vw, 56px);
      line-height: 1.05;
      letter-spacing: -1px;
    }

    .subtitle{
      margin: 0;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.65;
      max-width: 56ch;
    }

    .actions{
      display:flex;
      flex-wrap:wrap;
      gap: 12px;
      margin-top: 18px;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      padding: 13px 16px;
      border-radius: 14px;
      border: 1px solid var(--border);
      text-decoration:none;
      font-weight: 800;
      letter-spacing: .2px;
      color: var(--text);
      background: rgba(255,255,255,.03);
      box-shadow: var(--shadow2);
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease;
      min-width: 190px;
      user-select:none;
    }
    .btn:hover{
      transform: translateY(-2px);
      border-color: rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
    }
    .btn:active{ transform: translateY(0px); }
    .btn:focus-visible{
      outline:none;
      box-shadow: 0 0 0 4px rgba(43,213,118,.20), var(--shadow2);
    }

    .btn-primary{
      border-color: rgba(43,213,118,.35);
      background: linear-gradient(135deg, rgba(43,213,118,.92), rgba(43,213,118,.55));
      box-shadow: 0 18px 45px rgba(43,213,118,.14);
      color: #06110b;
    }
    .btn-primary:hover{
      box-shadow: 0 22px 58px rgba(43,213,118,.18);
    }

    .btn-outline{
      border-color: rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      color: var(--text);
    }

    .mini{
      display:flex;
      gap: 12px;
      margin-top: 18px;
      color: var(--muted2);
      font-size: 13px;
      flex-wrap:wrap;
    }
    .mini a{
      color: var(--muted);
      text-decoration:none;
      border-bottom: 1px dashed rgba(255,255,255,.22);
    }
    .mini a:hover{
      color: var(--text);
      border-bottom-color: rgba(255,255,255,.4);
    }

    .side{
      display:flex;
      flex-direction:column;
      gap: 12px;
    }

    .panel{
      background: linear-gradient(180deg, rgba(19,22,33,.85), rgba(19,22,33,.55));
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow2);
      padding: 18px;
      position:relative;
      overflow:hidden;
      min-height: 150px;
    }

    .panel h3{
      margin: 0 0 10px;
      font-size: 14px;
      letter-spacing: .25px;
      color: rgba(232,235,244,.92);
      display:flex;
      align-items:center;
      gap: 10px;
    }

    .badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      font-size: 12px;
      color: var(--muted);
      border: 1px solid var(--border);
      background: rgba(255,255,255,.03);
      padding: 8px 10px;
      border-radius: 12px;
    }

    .feat{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }
    .feat .item{
      border: 1px solid var(--border);
      background: rgba(255,255,255,.03);
      border-radius: var(--radius2);
      padding: 10px 10px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.4;
    }
    .feat .item b{
      color: var(--text);
      display:block;
      margin-bottom: 3px;
      font-size: 13px;
    }

    footer{
      margin-top:auto;
      padding: 26px 0 30px;
      color: rgba(154,163,191,.65);
      font-size: 13px;
      text-align:center;
      position:relative;
      z-index:1;
    }

    /* Redirect state */
    .redirect{
      max-width: 760px;
      margin: 18vh auto 0;
      padding: 0 18px;
      position:relative;
      z-index:2;
      text-align:center;
    }
    .spinner{
      width: 46px;
      height: 46px;
      border-radius: 999px;
      border: 3px solid rgba(255,255,255,.10);
      border-top-color: rgba(43,213,118,.95);
      margin: 0 auto 16px;
      animation: spin .9s linear infinite;
      box-shadow: 0 0 30px rgba(43,213,118,.12);
    }
    @keyframes spin{ to{ transform: rotate(360deg); } }

    @media (max-width: 900px){
      .hero{ grid-template-columns: 1fr; }
      .btn{ width: 100%; min-width: unset; }
      .feat{ grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>

<% if (user) { %>
  <div class="redirect">
    <div class="spinner"></div>
    <h1 style="margin:0 0 8px; font-size: 34px; letter-spacing:-.8px;">Redirecting to Selector</h1>
    <p class="subtitle" style="margin:0 auto; max-width: 52ch;">
      You’re logged in. Landing pages are for strangers.
    </p>
    <div class="actions" style="justify-content:center; margin-top:16px;">
      <a class="btn btn-primary" href="/selector">Continue</a>
      <a class="btn btn-outline" href="/logout">Log out</a>
    </div>

    <script>
      // client-side redirect (immediate)
      window.location.replace("/selector");
    </script>
  </div>

<% } else { %>

  <div class="wrap">
    <div class="topbar">
      <a class="brand" href="/">
        <div class="logo"></div>
        <div>
          <strong>Bright Dashboard</strong>
          <span>Ops-grade control panel</span>
        </div>
      </a>

      <a class="pill" href="/api/login">
        <span class="dot"></span>
        Login
      </a>
    </div>

    <div class="hero">
      <section class="card">
        <div class="card-inner">
          <h1>Control, not clutter.</h1>
          <p class="subtitle">
            Manage servers, configure features, and keep the bot locked down without a UI that screams “template”.
          </p>

          <div class="actions">
            <a class="btn btn-primary" href="/api/login">Login with Discord</a>
            <a class="btn btn-outline" href="/privacy">Privacy</a>
            <a class="btn btn-outline" href="/tos">Terms</a>
          </div>

          <div class="mini">
            <span>Secure OAuth</span>
            <span>•</span>
            <span>Fast selector</span>
            <span>•</span>
            <span><a href="/api/login">Get started</a></span>
          </div>
        </div>
      </section>

      <aside class="side">
        <div class="panel">
          <h3>
            <span style="width:10px;height:10px;border-radius:50%;background:rgba(43,213,118,.95);box-shadow:0 0 0 4px rgba(43,213,118,.10);display:inline-block;"></span>
            What you can do
          </h3>

          <div class="feat">
            <div class="item">
              <b>Server Selector</b>
              Pick a guild and jump into settings.
            </div>
            <div class="item">
              <b>Feature Toggles</b>
              Enable modules without chaos.
            </div>
            <div class="item">
              <b>Audit-friendly UI</b>
              Clear layout, readable states.
            </div>
            <div class="item">
              <b>Fast access</b>
              Less clicking, more control.
            </div>
          </div>
        </div>

        <div class="panel">
          <h3>
            <span style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.75);box-shadow:0 0 0 4px rgba(255,255,255,.06);display:inline-block;"></span>
            Status
          </h3>
          <div class="badge">Dashboard online • <%= new Date().toLocaleString() %></div>
          <p style="margin:12px 0 0; color: var(--muted); font-size: 13px; line-height:1.6;">
            Login to view the servers you can manage and configure Bright properly.
          </p>
        </div>
      </aside>
    </div>

    <footer>
      © <%= new Date().getFullYear() %> Bright Dashboard. All Rights Reserved.
    </footer>
  </div>

<% } %>

</body>
</html>
